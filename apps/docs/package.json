{
  "name": "@pofile-ts/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build && cp -r build/client/assets build/client/pofile-ts/ && cp build/client/favicon.ico build/client/logo.svg build/client/pofile-ts/",
    "dev": "react-router dev",
    "start": "serve ./build/client",
    "types:check": "react-router typegen && fumadocs-mdx && tsc --noEmit",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "@react-router/node": "^7.13.1",
    "fumadocs-core": "16.6.17",
    "fumadocs-mdx": "14.2.10",
    "fumadocs-typescript": "^5.1.5",
    "fumadocs-ui": "16.6.17",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-router-devtools": "^6.2.0",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
