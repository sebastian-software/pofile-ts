{
  "name": "pofile-ts-monorepo",
  "private": true,
  "description": "Monorepo for pofile-ts and documentation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastian-software/pofile-ts.git"
  },
  "scripts": {
    "build": "pnpm --filter pofile-ts build",
    "dev": "pnpm --filter pofile-ts dev",
    "test": "pnpm --filter pofile-ts test",
    "test:rust": "cargo test --workspace",
    "test:coverage": "pnpm --filter pofile-ts test:coverage",
    "lint": "pnpm --filter pofile-ts lint",
    "lint:rust": "cargo clippy --workspace --all-targets -- -D warnings",
    "lint:fix": "pnpm --filter pofile-ts lint:fix",
    "format": "prettier --write .",
    "format:rust": "cargo fmt --all",
    "format:check": "prettier --check .",
    "format:check:rust": "cargo fmt --all --check",
    "typecheck": "pnpm --filter pofile-ts typecheck",
    "check:rust": "cargo check --workspace",
    "prepare": "husky",
    "bench": "pnpm --filter pofile-ts-benchmark bench",
    "bench:generate": "pnpm --filter pofile-ts-benchmark generate-fixture",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm --filter docs build"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "packageManager": "pnpm@10.31.0"
}
